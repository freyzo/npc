{
  "manifest_version": 3,
  "name": "NPC",
  "version": "0.1.0",
  "description": "Connect your browser to NPC — handles the side quests.",
  "permissions": [
    "debugger",
    "tabs",
    "activeTab",
    "offscreen",
    "alarms",
    "cookies"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "NPC — connect this tab",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
